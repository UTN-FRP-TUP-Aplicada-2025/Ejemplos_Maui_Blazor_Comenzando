@using MudBlazor
@* NavMenu reescrito con MudBlazor.
   Requiere que en MauiProgram.cs esté registrado:
       builder.Services.AddMudServices();
   Y en App.razor / MainLayout.razor los providers:
       <MudThemeProvider />
       <MudPopoverProvider />
       <MudDialogProvider />
       <MudSnackbarProvider />
*@

<MudDrawerHeader Class="pa-2">
    <MudText Typo="Typo.h6">MB_HolaMundo</MudText>
</MudDrawerHeader>

<MudNavMenu Bordered="true" Color="Color.Primary">
    <MudNavLink Href=""
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Home">
        Home
    </MudNavLink>

    <MudNavLink Href="counter"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.AddBox">
        Counter
    </MudNavLink>

    <MudNavLink Href="weather"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.List">
        Weather
    </MudNavLink>
</MudNavMenu>